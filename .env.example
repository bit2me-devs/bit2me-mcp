# ============================================================================
# BIT2ME API CREDENTIALS (Required)
# ============================================================================
# Get your API keys from: https://app.bit2me.com/profile/api
BIT2ME_API_KEY=your_api_key_here
BIT2ME_API_SECRET=your_api_secret_here

# ============================================================================
# API CONFIGURATION (Optional)
# ============================================================================

# Request timeout in milliseconds (default: 30000)
BIT2ME_REQUEST_TIMEOUT=30000

# Maximum number of retries for rate-limited requests (default: 3)
BIT2ME_MAX_RETRIES=3

# Base delay for exponential backoff in milliseconds (default: 1000)
BIT2ME_RETRY_BASE_DELAY=1000

# Session cookie name used for JWT-based authentication (default: b2m-atoken)
# Override this in non-production environments (e.g. qa-b2m-atoken for QA)
# BIT2ME_SESSION_COOKIE_NAME=b2m-atoken

# ============================================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================================

# Log level: debug, info, warn, error (default: info)
BIT2ME_LOG_LEVEL=info

# Log output format: "pretty" (default, human-readable) or "json" (one JSON
# object per line, suitable for log aggregators like Loki, Datadog, CloudWatch).
# All logs are written to stderr; stdout is reserved for the MCP JSON-RPC frame.
# LOG_FORMAT=json

# ============================================================================
# AUDIT LOG (Optional)
# ============================================================================

# When set, every successful or failed write tool (orders, withdrawals, loans,
# earn deposits, etc.) is appended as a single JSON line to this file. Each
# entry contains the tool name, sanitised arguments, outcome, correlation ID,
# and a SHA-256 fingerprint of the session token (never the token itself).
# If unset, audit lines are emitted via the regular logger with `audit: true`.
# AUDIT_LOG_PATH=/var/log/bit2me-mcp/audit.log

# ============================================================================
# HTTP / SSE TRANSPORT (only used by `bit2me-mcp-http` binary)
# ============================================================================
# The HTTP binary lets multiple tenants share a single server: each request
# carries its own credentials in headers (`X-Bit2Me-Api-Key` +
# `X-Bit2Me-Api-Secret`, or `Authorization: Bearer <jwt>`). TLS termination
# is delegated to a reverse proxy (nginx, traefik, caddy, ...).

# Bind host (default: 127.0.0.1)
# MCP_HTTP_HOST=127.0.0.1

# Listen port (default: 3000)
# MCP_HTTP_PORT=3000

# Auth mode: "api_key" (default), "jwt" or "both"
#   - api_key: requires X-Bit2Me-Api-Key + X-Bit2Me-Api-Secret headers
#   - jwt:     requires Authorization: Bearer <jwt> header
#   - both:    accepts either
# MCP_HTTP_AUTH_MODE=api_key

# Reverse-proxy trust policy. Default: false (the server uses the raw
# socket address and ignores X-Forwarded-* headers, so a directly-
# exposed deployment cannot have its rate limit bypassed via spoofed
# client IPs). Only enable this if your reverse proxy strips and
# rewrites X-Forwarded-* and you trust the network path.
#   - false      : ignore X-Forwarded-* (recommended default)
#   - true       : trust all upstreams (dangerous; only for closed networks)
#   - loopback   : trust 127.0.0.0/8 and ::1
#   - linklocal  : trust loopback + 169.254.0.0/16
#   - <CIDR list>: comma-separated CIDRs, e.g. "10.0.0.0/8,192.168.0.0/16"
# MCP_HTTP_TRUST_PROXY=false
