# Node.js & TypeScript project
node_modules/
.pnpm-store/

# Build output
/dist/
/build/

# TypeScript cache
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example
.env.local
.env.*.local
.envrc

# Logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS generated files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.iml

# Cursor (cachés y locales; las reglas y skills SÍ se versionan)
.cursor/cache/
.cursor/logs/
.cursor/tmp/

# Test coverage
coverage/

# Test credentials (contains secrets)
test-credentials.js

# Miscellaneous
*.tgz
*.zip
*.pem
*.key

# Temporary files
tmp/
*.tmp

# Documentación interna y temporal (uso del equipo, no se versiona).
# Excepciones: docs/stack/ (fuente de verdad de tooling/stack) y docs/adr/
# (Architectural Decision Records) SÍ se versionan.
# Nota: usamos docs/* (no docs/) para que git pueda re-incluir las excepciones.
docs/*
!docs/stack/
!docs/adr/

# Assets locales (imágenes temporales)
assets/
