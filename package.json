{
    "name": "@bit2me/mcp-server",
    "version": "4.1.4",
    "description": "Bit2Me MCP Server",
    "type": "module",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        }
    },
    "files": [
        "build",
        "data",
        "README.md",
        "LICENSE"
    ],
    "packageManager": "pnpm@10.0.0",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "bin": {
        "bit2me-mcp-server": "./build/index.js",
        "bit2me-mcp-http": "./build/index-http.js"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:llms": "node scripts/generate-llms.js",
        "build:docs": "node scripts/generate-tools-docs.js",
        "prepublishOnly": "pnpm run validate && pnpm run build",
        "start": "node build/index.js",
        "dev": "pnpm dlx @modelcontextprotocol/inspector node build/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "RUN_E2E=true vitest run tests/e2e",
        "test:e2e:watch": "RUN_E2E=true vitest tests/e2e",
        "test:fuzz": "vitest run tests/fuzz.test.ts",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/**/*.ts tests/**/*.ts --fix",
        "lint:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "eslint": "eslint",
        "eslint:legacy": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
        "eslint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
        "prettier": "prettier --write .",
        "audit": "pnpm audit --audit-level=high",
        "knip": "knip",
        "secret-scan": "bash -c 'if command -v gitleaks >/dev/null 2>&1; then gitleaks protect --staged --verbose --redact; else echo \"ERROR: gitleaks is required for the pre-commit secret scan. Install it from https://github.com/gitleaks/gitleaks (e.g. \\`brew install gitleaks\\` or \\`apt install gitleaks\\`).\" >&2; exit 1; fi' --",
        "clean": "rm -rf build coverage",
        "publint": "publint",
        "validate": "pnpm run typecheck && pnpm run lint && pnpm run publint && pnpm test",
        "prepare": "husky"
    },
    "keywords": [
        "mcp",
        "bit2me",
        "server"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bit2me-devs/bit2me-mcp.git"
    },
    "homepage": "https://mcp.bit2me.com",
    "author": "Bit2Me",
    "license": "MIT",
    "dependencies": {
        "@fastify/rate-limit": "^10.3.0",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "axios": "^1.16.0",
        "decimal.js": "^10.6.0",
        "dotenv": "^17.4.2",
        "fastify": "^5.8.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@eslint/js": "^9.39.4",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/node": "^25.6.2",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^9.39.4",
        "eslint-plugin-security": "^4.0.0",
        "fast-check": "^4.7.0",
        "globals": "^17.6.0",
        "html-minifier-terser": "^7.2.0",
        "husky": "^9.1.7",
        "knip": "^6.12.2",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "publint": "^0.3.20",
        "semantic-release": "^25.0.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vite": "7.3.3",
        "vitest": "^4.1.5"
    },
    "lint-staged": {
        "*": [
            "pnpm run secret-scan"
        ],
        "package.json": [
            "pnpm run audit"
        ],
        "pnpm-lock.yaml": [
            "pnpm run audit"
        ],
        "*.ts": [
            "pnpm exec eslint --fix",
            "prettier --write",
            "vitest related --run"
        ],
        "*.{css,html,json,md}": [
            "prettier --write"
        ]
    }
}
